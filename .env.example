# ============================================================
# TradeIQ — Environment Variable Template
# ============================================================
# Copy this file to .env in the project ROOT and fill in your
# real values. This file (.env.example) is safe to commit.
# The actual .env is git-ignored.
# ============================================================


# ── Database ─────────────────────────────────────────────────
# Local SQLite (default — no external setup needed)
DATABASE_URL=sqlite+aiosqlite:///./tradeiq.db
# PostgreSQL on Proxmox / remote server (uncomment to use):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/tradeiq_db


# ── Market Data ───────────────────────────────────────────────
# Finnhub: free news API. Get key at https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Twelve Data: alternative market data. https://twelvedata.com/
TWELVE_DATA_KEY=your_twelve_data_key_here


# ── Databricks (Historical Aggregations) ─────────────────────
DATABRICKS_HOST=your_databricks_host_here
DATABRICKS_TOKEN=your_databricks_token_here
DATABRICKS_WAREHOUSE_ID=your_databricks_warehouse_id_here


# ── Anthropic Claude (AI Chat Assistant) ─────────────────────
# Powers the AI chat panel in the frontend. Paid API.
# Get your key at: https://console.anthropic.com/
ANTHROPIC_KEY=your_anthropic_key_here


# ── Telegram Alerts (FREE push notifications) ─────────────────
# 1. Open Telegram → search @BotFather → /newbot → copy BOT_TOKEN
# 2. Message your bot once, then call GET /alerts/telegram/chat-id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here


# ── Reddit Sentiment (FREE) ───────────────────────────────────
# Register at: https://www.reddit.com/prefs/apps → create "script" app
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=TradeIQ/1.0


# ── Node Proxy Server ─────────────────────────────────────────
PORT=3000


# ── Frontend API URLs (Vite — must be prefixed with VITE_) ───
VITE_PROXY_URL=http://localhost:3000
VITE_STAP_API=http://localhost:8000


# ── Python Backend App ────────────────────────────────────────
ENV=development
APP_PORT=8000
FRONTEND_URL=http://localhost:5173


# ── JWT Authentication ────────────────────────────────────────
# Generate a strong secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE-ME-in-production-use-secrets-token-urlsafe-64
JWT_ALGORITHM=HS256


# ── Stripe Billing (optional — leave empty for demo mode) ────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_ENTERPRISE=
