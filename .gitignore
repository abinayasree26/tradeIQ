# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/

# ── Environment / secrets — NEVER commit these ────────────────
# Ignore all .env files at any depth
.env
**/.env
*.env
# Allow example templates (safe to commit)
!.env.example
!**/.env.example

# ── Node ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
.pnp/
.pnp.js

# ── Vite build output ─────────────────────────────────────────
frontend/dist/
frontend/.vite/

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── DB / temp ─────────────────────────────────────────────────
*.sqlite
*.db
C:/Temp/
