# ============================================================
# STAP — Smart Technical Analysis Platform
# Copy this to .env and fill your values
# ============================================================

# ── Database — VM 104 moneyflow-server (192.168.86.245) ──────
DATABASE_URL=postgresql+asyncpg://tradeiq:tradeiq123@192.168.86.245:5432/tradeiq_db

# ── App ───────────────────────────────────────────────────────
ENV=development
APP_PORT=8000

# ── Finnhub (market news — free) ─────────────────────────────
FINNHUB_API_KEY=your_finnhub_key_here

# ── Anthropic Claude (AI chat) ────────────────────────────────
ANTHROPIC_KEY=your_anthropic_key_here

# ── Databricks ────────────────────────────────────────────────
DATABRICKS_HOST=your_workspace.cloud.databricks.com
DATABRICKS_TOKEN=your_token_here
DATABRICKS_WAREHOUSE_ID=your_warehouse_id

# ── Telegram Alerts (FREE) ────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Reddit Sentiment (FREE) ───────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=STAP/1.0
